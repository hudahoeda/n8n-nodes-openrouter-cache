{
	"name": "n8n-nodes-openrouter-cache-chat-model",
	"version": "0.2.0",
	"description": "OpenRouter Chat Model with prompt caching support for n8n AI Agent workflows",
	"license": "MIT",
	"author": {
		"name": "Huda",
		"email": "revoutech@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/hudahoeda/n8n-nodes-openrouter-cache.git"
	},
	"keywords": [
		"n8n-community-node-package",
		"openrouter",
		"prompt-caching",
		"ai",
		"langchain"
	],
	"scripts": {
		"build": "tsc && npm run copy-static",
		"copy-static": "cp nodes/OpenRouterCacheChatModel/*.svg dist/nodes/OpenRouterCacheChatModel/",
		"dev": "tsc --watch",
		"test": "jest --coverage",
		"test:watch": "jest --watch"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"nodes": [
			"dist/nodes/OpenRouterCacheChatModel/OpenRouterCacheChatModel.node.js"
		]
	},
	"dependencies": {
		"@langchain/openai": "^0.5.0"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^20.19.39",
		"jest": "^30.3.0",
		"ts-jest": "^29.4.9",
		"typescript": "~5.9.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
